LABELS = {0: "🟢 BAIXO RISCO", 1: "🟡 RISCO MÉDIO", 2: "🔴 RISCO ALTO"}

def alertas_clinicos(glicose, pressao, imc, colesterol):
    alertas = []
    if glicose >= 126:   alertas.append("⚠  Glicose diabética (≥ 126 mg/dL)")
    elif glicose >= 100: alertas.append("⚠  Glicose pré-diabética (100–125 mg/dL)")
    if pressao >= 160:   alertas.append("⚠  Hipertensão estágio 2 (≥ 160 mmHg)")
    elif pressao >= 130: alertas.append("⚠  Hipertensão estágio 1 (130–159 mmHg)")
    if imc >= 30:        alertas.append(f"⚠  Obesidade (IMC {imc:.1f} ≥ 30)")
    elif imc >= 25:      alertas.append(f"⚠  Sobrepeso (IMC {imc:.1f} entre 25–29.9)")
    if colesterol >= 240:  alertas.append("⚠  Colesterol alto (≥ 240 mg/dL)")
    elif colesterol >= 200:alertas.append("⚠  Colesterol limítrofe (200–239 mg/dL)")
    return alertas

def prever_paciente(nome, idade, glicose, pressao, imc, colesterol):
    x      = np.array([[idade, glicose, pressao, imc, colesterol]], dtype=float)
    x_sc   = scaler.transform(x)
