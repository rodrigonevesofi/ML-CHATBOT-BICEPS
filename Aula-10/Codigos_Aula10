import pandas as pd
import numpy as np
import warnings
warnings.filterwarnings("ignore")

from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.ensemble import RandomForestClassifier

# ─────────────────────────────────────────────────────────────
# PASSO 1 — Gerar o dataset internamente (sem depender de CSV)
# ─────────────────────────────────────────────────────────────
np.random.seed(42)
N = 2000

nomes_lista = [
    "Lucas","Gabriel","Mateus","Pedro","Rafael","Bruno","Caio","Diego",
    "Eduardo","Felipe","Ana","Beatriz","Camila","Diana","Fernanda",
    "Gabriela","Helena","Isabela","Juliana","Karina","Larissa","Mariana",
    "Natália","Olivia","Patrícia","Roberta","Sabrina","Tatiana","Vanessa","Alice"
]
nomes       = np.random.choice(nomes_lista, size=N)
idade       = np.random.randint(18, 100, size=N)
glicose     = np.clip(np.random.normal(100, 30, N), 60, 300).round(1)
pressao     = np.clip(np.random.normal(120, 20, N), 80, 220).round(1)
imc         = np.clip(np.random.normal(26,   5, N), 15,  50).round(1)
colesterol  = np.clip(np.random.normal(200, 40, N), 100, 350).round(1)

def calcular_score(g, pa, bmi, col, age):
    s = np.zeros(N, dtype=int)
    s += np.where(g   >= 126, 2, np.where(g   >= 100, 1, 0))
    s += np.where(pa  >= 140, 2, np.where(pa  >= 120, 1, 0))
    s += np.where(bmi >= 30,  2, np.where(bmi >= 25,  1, 0))
    s += np.where(col >= 240, 2, np.where(col >= 200, 1, 0))
    s += np.where(age >= 60,  2, np.where(age >= 45,  1, 0))
    return s

score = calcular_score(glicose, pressao, imc, colesterol, idade)
ruido = np.random.choice([0]*9 + [1, -1], size=N)
risco = np.where(np.clip(score + ruido, 0, 10) <= 2, 0,
        np.where(np.clip(score + ruido, 0, 10) <= 5, 1, 2))

df = pd.DataFrame({
    "nome": nomes, "idade": idade, "glicose": glicose,
    "pressao_arterial": pressao, "imc": imc,
    "colesterol": colesterol, "risco": risco
})

# ─────────────────────────────────────────────────────────────
# PASSO 2 — Treinar o modelo
# ─────────────────────────────────────────────────────────────
X = df[["idade","glicose","pressao_arterial","imc","colesterol"]]
y = df["risco"]

X_train, _, y_train, _ = train_test_split(
    X, y, test_size=0.2, stratify=y, random_state=42
)

scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)

modelo = RandomForestClassifier(n_estimators=100, random_state=42)
modelo.fit(X_train_scaled, y_train)

print("✅ Modelo treinado com sucesso.\n")

