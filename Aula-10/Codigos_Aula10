    print(f"  Paciente         : {nome}")
    print(f"  Idade            : {idade} anos")
    print(f"  Glicose          : {glicose} mg/dL")
    print(f"  Pressão Arterial : {pressao} mmHg")
    print(f"  IMC              : {imc} kg/m²")
    print(f"  Colesterol       : {colesterol} mg/dL")
    print("─" * 60)
    print(f"\n  ► RISCO PREVISTO : {LABELS[classe]}")
    print(f"\n  Probabilidades:")
    for i, lbl in enumerate(["Baixo", "Médio", "Alto "]):
        barra = "█" * int(probs[i] * 30)
        print(f"    {lbl} : {probs[i]*100:5.1f}%  {barra}")
    al = alertas_clinicos(glicose, pressao, imc, colesterol)
    if al:
        print("\n  Alertas Clínicos:")
        for a in al: print(f"    {a}")
    else:
        print("\n  ✓ Nenhum alerta clínico.")
    print("═" * 60)


