# ─────────────────────────────────────────────────────────────
# PASSO 4 — FUNÇÃO DE EXIBIÇÃO DO RESULTADO
# ─────────────────────────────────────────────────────────────
def avaliar_paciente(p, numero):
    entrada = pd.DataFrame([{
        "idade"           : p["idade"],
        "glicose"         : p["glicose"],
        "pressao_arterial": p["pressao_arterial"],
        "imc"             : p["imc"],
        "colesterol"      : p["colesterol"]
    }])

    entrada_norm   = scaler.transform(entrada)
    classe         = modelo.predict(entrada_norm)[0]
    probabilidades = modelo.predict_proba(entrada_norm)[0]

    labels = {
        0: ("BAIXO RISCO", "✅"),
        1: ("RISCO MÉDIO",  "⚠️ "),
        2: ("RISCO ALTO",   "🔴")
    }
    interpretacoes = {
        0: "Perfil saudável. Manter hábitos e checkups anuais.",
        1: "Indicadores limítrofes. Avaliação médica preventiva recomendada.",
        2: "Múltiplos fatores de risco. Encaminhamento médico imediato."
    }

    nome_classe, icone = labels[classe]

    print(f"{'━'*54}")
    print(f"  TESTE {numero} — {p['nome'].upper()}")
    print(f"{'━'*54}")
    print(f"  Idade          : {p['idade']} anos")
    print(f"  Glicose        : {p['glicose']:.1f} mg/dL")
    print(f"  Pressão art.   : {p['pressao_arterial']:.1f} mmHg")
    print(f"  IMC            : {p['imc']:.1f} kg/m²")
    print(f"  Colesterol     : {p['colesterol']:.1f} mg/dL")
    print(f"  {'─'*50}")

    print("  Probabilidades:")
    nomes_cls = ["Baixo risco", "Risco médio", "Risco alto"]
    for i, (prob, lbl) in enumerate(zip(probabilidades, nomes_cls)):
        blocos  = int(prob * 28)
        barra   = "█" * blocos + "░" * (28 - blocos)
        seta    = " ◄ previsto" if i == classe else ""
        print(f"    {lbl:<13}: {barra}  {prob*100:5.1f}%{seta}")

    # Fatores de risco
    fatores = []
    if p["glicose"]         >= 126: fatores.append(f"glicose elevada ({p['glicose']} mg/dL)")
    elif p["glicose"]       >= 100: fatores.append(f"pré-diabetes ({p['glicose']} mg/dL)")
    if p["pressao_arterial"]>= 140: fatores.append(f"hipertensão ({p['pressao_arterial']} mmHg)")
    elif p["pressao_arterial"]>=120: fatores.append(f"pré-hipertensão ({p['pressao_arterial']} mmHg)")
    if p["imc"]             >= 30:  fatores.append(f"obesidade (IMC {p['imc']})")
    elif p["imc"]           >= 25:  fatores.append(f"sobrepeso (IMC {p['imc']})")
    if p["colesterol"]      >= 240: fatores.append(f"colesterol alto ({p['colesterol']} mg/dL)")
    elif p["colesterol"]    >= 200: fatores.append(f"colesterol limítrofe ({p['colesterol']} mg/dL)")
    if p["idade"]           >= 60:  fatores.append(f"idade ≥ 60 anos ({p['idade']} anos)")

    print(f"\n  ► Diagnóstico  : {icone}  {nome_classe}")
    print(f"  ► Interpretação: {interpretacoes[classe]}")
    if fatores:
        print(f"  ► Fatores      : {', '.join(fatores)}")
    else:
        print("  ► Fatores      : nenhum fator de risco identificado")
    print()

    return (p["nome"], classe, nome_classe, icone)

